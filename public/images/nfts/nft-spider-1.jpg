<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
  <!-- NFT Ndop Spider Genesis - Digital Art -->
  <defs>
    <radialGradient id="bg-gradient">
      <stop offset="0%" style="stop-color:#1B3A5C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0A1929;stop-opacity:1" />
    </radialGradient>
    
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="500" height="500" fill="url(#bg-gradient)"/>
  
  <!-- Digital grid -->
  <g opacity="0.2" stroke="#FFD700" stroke-width="0.5">
    <line x1="0" y1="100" x2="500" y2="100"/>
    <line x1="0" y1="200" x2="500" y2="200"/>
    <line x1="0" y1="300" x2="500" y2="300"/>
    <line x1="0" y1="400" x2="500" y2="400"/>
    <line x1="100" y1="0" x2="100" y2="500"/>
    <line x1="200" y1="0" x2="200" y2="500"/>
    <line x1="300" y1="0" x2="300" y2="500"/>
    <line x1="400" y1="0" x2="400" y2="500"/>
  </g>
  
  <!-- Glowing spider (center) -->
  <g transform="translate(250, 250)" filter="url(#glow)">
    <!-- Body -->
    <ellipse rx="50" ry="70" fill="#FFD700" opacity="0.9"/>
    <ellipse rx="45" ry="65" fill="#D4A574"/>
    
    <!-- Head -->
    <circle cy="-60" r="30" fill="#FFD700" opacity="0.9"/>
    <circle cy="-60" r="25" fill="#D4A574"/>
    
    <!-- Eyes glowing -->
    <circle cx="-10" cy="-65" r="6" fill="#FFFFFF"/>
    <circle cx="10" cy="-65" r="6" fill="#FFFFFF"/>
    <circle cx="-10" cy="-65" r="3" fill="#00FFFF"/>
    <circle cx="10" cy="-65" r="3" fill="#00FFFF"/>
    
    <!-- Decorative patterns -->
    <g stroke="#1B3A5C" stroke-width="4" fill="none">
      <path d="M -30 -20 Q 0 -10 30 -20"/>
      <path d="M -30 0 Q 0 10 30 0"/>
      <path d="M -30 20 Q 0 30 30 20"/>
    </g>
    
    <!-- Glowing legs -->
    <g stroke="#FFD700" stroke-width="8" fill="none" opacity="0.8" stroke-linecap="round">
      <path d="M -50 -30 Q -100 -80 -140 -120"/>
      <path d="M -50 -10 Q -110 -30 -150 -50"/>
      <path d="M -50 10 Q -110 30 -150 50"/>
      <path d="M -50 30 Q -100 80 -140 120"/>
      
      <path d="M 50 -30 Q 100 -80 140 -120"/>
      <path d="M 50 -10 Q 110 -30 150 -50"/>
      <path d="M 50 10 Q 110 30 150 50"/>
      <path d="M 50 30 Q 100 80 140 120"/>
    </g>
    
    <!-- Inner glow legs -->
    <g stroke="#00FFFF" stroke-width="3" fill="none" opacity="0.6" stroke-linecap="round">
      <path d="M -50 -30 Q -100 -80 -140 -120"/>
      <path d="M -50 -10 Q -110 -30 -150 -50"/>
      <path d="M -50 10 Q -110 30 -150 50"/>
      <path d="M -50 30 Q -100 80 -140 120"/>
      
      <path d="M 50 -30 Q 100 -80 140 -120"/>
      <path d="M 50 -10 Q 110 -30 150 -50"/>
      <path d="M 50 10 Q 110 30 150 50"/>
      <path d="M 50 30 Q 100 80 140 120"/>
    </g>
  </g>
  
  <!-- Digital web background -->
  <g opacity="0.3" stroke="#FFD700" stroke-width="1" fill="none">
    <circle cx="250" cy="250" r="180"/>
    <circle cx="250" cy="250" r="220"/>
    <circle cx="250" cy="250" r="260"/>
    
    <line x1="250" y1="50" x2="250" y2="450"/>
    <line x1="50" y1="250" x2="450" y2="250"/>
    <line x1="100" y1="100" x2="400" y2="400"/>
    <line x1="400" y1="100" x2="100" y2="400"/>
  </g>
  
  <!-- NFT badge -->
  <g transform="translate(400, 80)">
    <rect x="-40" y="-15" width="80" height="30" rx="15" fill="#000000" opacity="0.8"/>
    <text x="0" y="5" text-anchor="middle" fill="#FFD700" font-family="Arial, sans-serif" font-size="14" font-weight="bold">#001</text>
  </g>
  
  <!-- Particle effects -->
  <g fill="#00FFFF" opacity="0.6">
    <circle cx="80" cy="120" r="2"/>
    <circle cx="420" cy="150" r="2"/>
    <circle cx="100" cy="380" r="2"/>
    <circle cx="380" cy="400" r="2"/>
    <circle cx="150" cy="80" r="2"/>
    <circle cx="350" cy="90" r="2"/>
  </g>
</svg>
