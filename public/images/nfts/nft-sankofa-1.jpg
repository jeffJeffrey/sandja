<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="500" height="500">
  <!-- NFT Sankofa Animated -->
  <defs>
    <linearGradient id="bg-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8B4513;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#654321;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#3D2817;stop-opacity:1" />
    </linearGradient>
    
    <filter id="neon-glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="500" height="500" fill="url(#bg-grad)"/>
  
  <!-- Concentric circles (time/history) -->
  <g opacity="0.2" stroke="#FFD700" stroke-width="1" fill="none">
    <circle cx="250" cy="250" r="200"/>
    <circle cx="250" cy="250" r="160"/>
    <circle cx="250" cy="250" r="120"/>
    <circle cx="250" cy="250" r="80"/>
  </g>
  
  <!-- Sankofa bird glowing -->
  <g transform="translate(250, 250)" filter="url(#neon-glow)">
    <!-- Bird body -->
    <ellipse cx="50" cy="0" rx="60" ry="40" fill="#FFD700" opacity="0.9"/>
    <ellipse cx="50" cy="0" rx="55" ry="35" fill="#8B4513"/>
    
    <!-- Wing -->
    <path d="M 10 -20 Q -40 -50 -80 -40 Q -70 -10 -20 -5 Z" fill="#FFD700" opacity="0.8"/>
    
    <!-- Tail feathers (forward) -->
    <g fill="#FFD700" opacity="0.9">
      <path d="M 110 -10 L 150 -20 L 145 -5 Z"/>
      <path d="M 110 0 L 160 0 L 155 15 Z"/>
      <path d="M 110 10 L 150 25 L 140 15 Z"/>
    </g>
    
    <!-- Long neck (curved back) -->
    <path d="M 10 0 Q -30 -10 -50 10 Q -60 25 -50 40" 
          stroke="#FFD700" stroke-width="14" fill="none" opacity="0.9"/>
    <path d="M 10 0 Q -30 -10 -50 10 Q -60 25 -50 40" 
          stroke="#8B4513" stroke-width="10" fill="none"/>
    
    <!-- Head looking back -->
    <circle cx="-50" cy="45" r="20" fill="#FFD700" opacity="0.9"/>
    <circle cx="-50" cy="45" r="17" fill="#8B4513"/>
    
    <!-- Eye -->
    <circle cx="-53" cy="42" r="4" fill="#FFFFFF"/>
    <circle cx="-53" cy="42" r="2" fill="#00FFFF"/>
    
    <!-- Beak -->
    <path d="M -68 45 L -85 45 L -80 50 Z" fill="#FFD700"/>
    
    <!-- Egg (knowledge from past) -->
    <ellipse cx="-80" cy="52" rx="8" ry="11" fill="#FFFFFF" opacity="0.9"/>
    <ellipse cx="-80" cy="52" rx="6" ry="9" fill="#FFD700" opacity="0.3"/>
    
    <!-- Legs -->
    <g stroke="#8B4513" stroke-width="4" stroke-linecap="round">
      <path d="M 35 30 L 35 55"/>
      <path d="M 30 55 L 40 55"/>
      
      <path d="M 65 30 L 65 55"/>
      <path d="M 60 55 L 70 55"/>
    </g>
  </g>
  
  <!-- Motion trails (animation effect) -->
  <g opacity="0.3" stroke="#FFD700" stroke-width="2" fill="none">
    <path d="M 150 200 Q 120 180 100 200"/>
    <path d="M 140 220 Q 110 200 90 220"/>
    <path d="M 350 230 Q 380 210 400 230"/>
    <path d="M 360 250 Q 390 230 410 250"/>
  </g>
  
  <!-- Time symbols -->
  <g fill="#FFD700" opacity="0.4">
    <text x="100" y="80" font-family="serif" font-size="40">⟲</text>
    <text x="380" y="420" font-family="serif" font-size="40">⟳</text>
  </g>
  
  <!-- NFT label -->
  <g transform="translate(400, 450)">
    <rect x="-45" y="-15" width="90" height="30" rx="15" fill="#000000" opacity="0.9"/>
    <text x="0" y="5" text-anchor="middle" fill="#FFD700" font-family="Arial, sans-serif" font-size="14" font-weight="bold">#012</text>
  </g>
  
  <!-- Glow particles -->
  <g fill="#FFD700" opacity="0.7">
    <circle cx="100" cy="100" r="3"/>
    <circle cx="400" cy="120" r="3"/>
    <circle cx="120" cy="380" r="3"/>
    <circle cx="380" cy="360" r="3"/>
    <circle cx="200" cy="80" r="2"/>
    <circle cx="300" cy="420" r="2"/>
  </g>
</svg>
