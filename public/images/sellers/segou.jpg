<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Ségou Artisans Co-op Avatar -->
  
  <!-- Background - Bogolan style -->
  <circle cx="100" cy="100" r="100" fill="#F5DEB3"/>
  
  <!-- Mud cloth pattern -->
  <g fill="#8B4513">
    <!-- Border -->
    <rect x="10" y="10" width="180" height="180" fill="none" stroke="#8B4513" stroke-width="6"/>
    
    <!-- Traditional patterns -->
    <rect x="20" y="20" width="30" height="30"/>
    <rect x="150" y="20" width="30" height="30"/>
    <rect x="20" y="150" width="30" height="30"/>
    <rect x="150" y="150" width="30" height="30"/>
  </g>
  
  <!-- Central symbol - mortar and pestle (artisan tool) -->
  <g transform="translate(100, 100)">
    <!-- Mortar -->
    <path d="M -30 20 L -25 40 L 25 40 L 30 20 Z" fill="#8B4513" stroke="#654321" stroke-width="2"/>
    <ellipse cy="20" rx="30" ry="8" fill="#654321"/>
    
    <!-- Pestle -->
    <rect x="-5" y="-40" width="10" height="50" rx="5" fill="#8B4513" stroke="#654321" stroke-width="2"/>
    <ellipse cy="-40" rx="8" ry="6" fill="#654321"/>
  </g>
  
  <!-- Decorative Bogolan symbols -->
  <g fill="#2F4F4F" opacity="0.7">
    <!-- Top -->
    <circle cx="100" cy="35" r="6"/>
    
    <!-- Bottom -->
    <circle cx="100" cy="165" r="6"/>
    
    <!-- Sides -->
    <circle cx="35" cy="100" r="6"/>
    <circle cx="165" cy="100" r="6"/>
  </g>
  
  <!-- Geometric patterns -->
  <g stroke="#8B4513" stroke-width="2" fill="none" opacity="0.6">
    <path d="M 60 60 L 70 70 M 70 60 L 60 70"/>
    <path d="M 130 60 L 140 70 M 140 60 L 130 70"/>
    <path d="M 60 130 L 70 140 M 70 130 L 60 140"/>
    <path d="M 130 130 L 140 140 M 140 130 L 130 140"/>
  </g>
  
  <!-- Text banner -->
  <g transform="translate(100, 170)">
    <rect x="-50" y="-10" width="100" height="20" rx="10" fill="#8B4513"/>
    <text x="0" y="5" text-anchor="middle" fill="#F5DEB3" font-family="Arial, sans-serif" font-size="11" font-weight="bold">SÉGOU</text>
  </g>
  
  <!-- Verified badge -->
  <g transform="translate(150, 150)">
    <circle r="15" fill="#FFD700"/>
    <path d="M -5 0 L 0 8 L 8 -5" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  
  <!-- Traditional dots decoration -->
  <g fill="#8B4513" opacity="0.5">
    <circle cx="50" cy="50" r="3"/>
    <circle cx="150" cy="50" r="3"/>
    <circle cx="50" cy="150" r="3"/>
    <circle cx="150" cy="150" r="3"/>
  </g>
</svg>
