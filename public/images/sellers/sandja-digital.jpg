<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- SANDJA Digital Art Avatar -->
  <defs>
    <linearGradient id="digital-bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1B3A5C;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#00FFFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FFD700;stop-opacity:1" />
    </linearGradient>
    
    <filter id="digital-glow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <circle cx="100" cy="100" r="100" fill="url(#digital-bg)"/>
  
  <!-- Digital grid -->
  <g opacity="0.3" stroke="#FFFFFF" stroke-width="0.5">
    <line x1="0" y1="50" x2="200" y2="50"/>
    <line x1="0" y1="100" x2="200" y2="100"/>
    <line x1="0" y1="150" x2="200" y2="150"/>
    <line x1="50" y1="0" x2="50" y2="200"/>
    <line x1="100" y1="0" x2="100" y2="200"/>
    <line x1="150" y1="0" x2="150" y2="200"/>
  </g>
  
  <!-- Main symbol - digital spider/network -->
  <g transform="translate(100, 100)" filter="url(#digital-glow)">
    <!-- Central node -->
    <circle r="25" fill="#FFFFFF" opacity="0.9"/>
    <circle r="20" fill="#1B3A5C"/>
    <circle r="12" fill="#00FFFF"/>
    
    <!-- Network connections -->
    <g stroke="#FFFFFF" stroke-width="3" opacity="0.8">
      <line x1="0" y1="0" x2="-60" y2="-60"/>
      <line x1="0" y1="0" x2="0" y2="-70"/>
      <line x1="0" y1="0" x2="60" y2="-60"/>
      <line x1="0" y1="0" x2="-70" y2="0"/>
      <line x1="0" y1="0" x2="70" y2="0"/>
      <line x1="0" y1="0" x2="-60" y2="60"/>
      <line x1="0" y1="0" x2="0" y2="70"/>
      <line x1="0" y1="0" x2="60" y2="60"/>
    </g>
    
    <!-- Outer nodes -->
    <g fill="#FFD700">
      <circle cx="-60" cy="-60" r="8"/>
      <circle cx="0" cy="-70" r="8"/>
      <circle cx="60" cy="-60" r="8"/>
      <circle cx="-70" cy="0" r="8"/>
      <circle cx="70" cy="0" r="8"/>
      <circle cx="-60" cy="60" r="8"/>
      <circle cx="0" cy="70" r="8"/>
      <circle cx="60" cy="60" r="8"/>
    </g>
    
    <!-- Inner nodes (cyan) -->
    <g fill="#00FFFF">
      <circle cx="-60" cy="-60" r="4"/>
      <circle cx="0" cy="-70" r="4"/>
      <circle cx="60" cy="-60" r="4"/>
      <circle cx="-70" cy="0" r="4"/>
      <circle cx="70" cy="0" r="4"/>
      <circle cx="-60" cy="60" r="4"/>
      <circle cx="0" cy="70" r="4"/>
      <circle cx="60" cy="60" r="4"/>
    </g>
  </g>
  
  <!-- Digital particles -->
  <g fill="#FFFFFF" opacity="0.8">
    <circle cx="30" cy="40" r="2"/>
    <circle cx="170" cy="50" r="2"/>
    <circle cx="40" cy="160" r="2"/>
    <circle cx="160" cy="150" r="2"/>
    <circle cx="80" cy="30" r="1.5"/>
    <circle cx="120" cy="170" r="1.5"/>
  </g>
  
  <!-- Text label -->
  <g transform="translate(100, 165)">
    <rect x="-45" y="-12" width="90" height="24" rx="12" fill="#000000" opacity="0.9"/>
    <text x="0" y="5" text-anchor="middle" fill="#00FFFF" font-family="monospace" font-size="11" font-weight="bold">SANDJA</text>
  </g>
  
  <!-- NFT indicator -->
  <g transform="translate(30, 30)">
    <rect x="-18" y="-10" width="36" height="20" rx="10" fill="#FFD700"/>
    <text x="0" y="5" text-anchor="middle" fill="#000000" font-family="Arial, sans-serif" font-size="10" font-weight="bold">NFT</text>
  </g>
  
  <!-- Verified badge -->
  <g transform="translate(150, 150)">
    <circle r="15" fill="#00FFFF"/>
    <path d="M -5 0 L 0 8 L 8 -5" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
</svg>
