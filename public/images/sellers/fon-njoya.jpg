<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Atelier Fon Njoya Avatar -->
  <defs>
    <radialGradient id="face-gradient">
      <stop offset="0%" style="stop-color:#8B6F47;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#654321;stop-opacity:1" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <circle cx="100" cy="100" r="100" fill="#1B3A5C"/>
  
  <!-- Traditional Ndop pattern background -->
  <g opacity="0.3">
    <circle cx="100" cy="100" r="90" fill="none" stroke="#D4A574" stroke-width="2"/>
    <circle cx="100" cy="100" r="80" fill="none" stroke="#FFFFFF" stroke-width="1"/>
  </g>
  
  <!-- Royal cap (traditional Bamiléké) -->
  <ellipse cx="100" cy="60" rx="45" ry="20" fill="#D4A574"/>
  <rect x="55" y="55" width="90" height="15" rx="5" fill="#1B3A5C"/>
  <circle cx="100" cy="55" r="8" fill="#D4A574"/>
  
  <!-- Face -->
  <ellipse cx="100" cy="110" rx="40" ry="48" fill="url(#face-gradient)"/>
  
  <!-- Eyes -->
  <ellipse cx="85" cy="105" rx="6" ry="8" fill="#FFFFFF"/>
  <ellipse cx="115" cy="105" rx="6" ry="8" fill="#FFFFFF"/>
  <circle cx="85" cy="106" r="4" fill="#3D2817"/>
  <circle cx="115" cy="106" r="4" fill="#3D2817"/>
  
  <!-- Nose -->
  <path d="M 100 115 L 95 125 L 100 127 L 105 125 Z" fill="#654321"/>
  
  <!-- Mouth (slight smile) -->
  <path d="M 85 135 Q 100 142 115 135" fill="none" stroke="#3D2817" stroke-width="2" stroke-linecap="round"/>
  
  <!-- Traditional facial marks -->
  <g stroke="#3D2817" stroke-width="1.5" opacity="0.7">
    <line x1="70" y1="100" x2="75" y2="100"/>
    <line x1="125" y1="100" x2="130" y2="100"/>
  </g>
  
  <!-- Traditional collar -->
  <path d="M 60 150 Q 100 160 140 150" fill="#D4A574"/>
  <circle cx="100" cy="155" r="5" fill="#1B3A5C"/>
  
  <!-- Verified badge -->
  <g transform="translate(145, 145)">
    <circle r="15" fill="#FFD700"/>
    <path d="M -5 0 L 0 8 L 8 -5" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
</svg>
