<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Bonwire Weavers Guild Logo/Avatar -->
  
  <!-- Background - Kente pattern -->
  <circle cx="100" cy="100" r="100" fill="#228B22"/>
  
  <!-- Kente stripes -->
  <g opacity="0.6">
    <rect x="0" y="0" width="200" height="40" fill="#FFD700"/>
    <rect x="0" y="80" width="200" height="40" fill="#FF6347"/>
    <rect x="0" y="160" width="200" height="40" fill="#000000"/>
  </g>
  
  <!-- Traditional loom (stylized) -->
  <g transform="translate(100, 100)">
    <!-- Loom frame -->
    <rect x="-50" y="-40" width="100" height="80" fill="none" stroke="#8B4513" stroke-width="4"/>
    
    <!-- Vertical threads -->
    <g stroke="#FFFFFF" stroke-width="1" opacity="0.8">
      <line x1="-40" y1="-35" x2="-40" y2="35"/>
      <line x1="-25" y1="-35" x2="-25" y2="35"/>
      <line x1="-10" y1="-35" x2="-10" y2="35"/>
      <line x1="5" y1="-35" x2="5" y2="35"/>
      <line x1="20" y1="-35" x2="20" y2="35"/>
      <line x1="35" y1="-35" x2="35" y2="35"/>
    </g>
    
    <!-- Woven pattern (Kente) -->
    <g>
      <rect x="-45" y="-25" width="90" height="8" fill="#FFD700"/>
      <rect x="-45" y="-10" width="90" height="8" fill="#FF6347"/>
      <rect x="-45" y="5" width="90" height="8" fill="#228B22"/>
      <rect x="-45" y="20" width="90" height="8" fill="#000000"/>
    </g>
    
    <!-- Shuttle -->
    <ellipse cx="0" cy="-5" rx="25" ry="6" fill="#8B4513" stroke="#654321" stroke-width="2"/>
  </g>
  
  <!-- Guild emblem -->
  <g transform="translate(100, 40)">
    <circle r="20" fill="#FFD700"/>
    <circle r="16" fill="#228B22"/>
    <circle r="12" fill="#FF6347"/>
    <circle r="8" fill="#000000"/>
    <circle r="4" fill="#FFFFFF"/>
  </g>
  
  <!-- Text banner -->
  <g transform="translate(100, 165)">
    <rect x="-60" y="-12" width="120" height="24" rx="12" fill="#000000" opacity="0.8"/>
    <text x="0" y="5" text-anchor="middle" fill="#FFD700" font-family="Arial, sans-serif" font-size="12" font-weight="bold">BONWIRE</text>
  </g>
  
  <!-- Verified badge -->
  <g transform="translate(150, 150)">
    <circle r="15" fill="#FFD700"/>
    <path d="M -5 0 L 0 8 L 8 -5" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  
  <!-- Decorative corners (Adinkra style) -->
  <g fill="#FFD700" opacity="0.5">
    <circle cx="20" cy="20" r="5"/>
    <circle cx="180" cy="20" r="5"/>
    <circle cx="20" cy="180" r="5"/>
    <circle cx="180" cy="180" r="5"/>
  </g>
</svg>
