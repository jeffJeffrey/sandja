<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="400" height="300">
  <!-- Ndop Royal Blue Fabric Pattern -->
  <defs>
    <!-- Indigo pattern -->
    <pattern id="indigo-bg" patternUnits="userSpaceOnUse" width="40" height="40">
      <rect width="40" height="40" fill="#1B3A5C"/>
      <circle cx="20" cy="20" r="3" fill="#2C5078" opacity="0.5"/>
    </pattern>
    
    <!-- Spider motif small -->
    <g id="small-spider">
      <circle r="8" fill="#D4A574"/>
      <line x1="-12" y1="-8" x2="-6" y2="-4" stroke="#D4A574" stroke-width="1.5"/>
      <line x1="-12" y1="0" x2="-8" y2="0" stroke="#D4A574" stroke-width="1.5"/>
      <line x1="-12" y1="8" x2="-6" y2="4" stroke="#D4A574" stroke-width="1.5"/>
      <line x1="12" y1="-8" x2="6" y2="-4" stroke="#D4A574" stroke-width="1.5"/>
      <line x1="12" y1="0" x2="8" y2="0" stroke="#D4A574" stroke-width="1.5"/>
      <line x1="12" y1="8" x2="6" y2="4" stroke="#D4A574" stroke-width="1.5"/>
    </g>
  </defs>
  
  <!-- Base fabric -->
  <rect width="400" height="300" fill="url(#indigo-bg)"/>
  
  <!-- Traditional Ndop border pattern -->
  <rect x="10" y="10" width="380" height="280" fill="none" stroke="#D4A574" stroke-width="3"/>
  <rect x="15" y="15" width="370" height="270" fill="none" stroke="#FFFFFF" stroke-width="1"/>
  
  <!-- Geometric patterns -->
  <g opacity="0.7">
    <!-- Horizontal dividers -->
    <line x1="30" y1="80" x2="370" y2="80" stroke="#D4A574" stroke-width="2"/>
    <line x1="30" y1="150" x2="370" y2="150" stroke="#D4A574" stroke-width="2"/>
    <line x1="30" y1="220" x2="370" y2="220" stroke="#D4A574" stroke-width="2"/>
  </g>
  
  <!-- Spider symbols -->
  <use href="#small-spider" x="100" y="50" opacity="0.8"/>
  <use href="#small-spider" x="200" y="50" opacity="0.8"/>
  <use href="#small-spider" x="300" y="50" opacity="0.8"/>
  
  <use href="#small-spider" x="100" y="115" opacity="0.8"/>
  <use href="#small-spider" x="200" y="115" opacity="0.8"/>
  <use href="#small-spider" x="300" y="115" opacity="0.8"/>
  
  <use href="#small-spider" x="100" y="185" opacity="0.8"/>
  <use href="#small-spider" x="200" y="185" opacity="0.8"/>
  <use href="#small-spider" x="300" y="185" opacity="0.8"/>
  
  <use href="#small-spider" x="100" y="250" opacity="0.8"/>
  <use href="#small-spider" x="200" y="250" opacity="0.8"/>
  <use href="#small-spider" x="300" y="250" opacity="0.8"/>
  
  <!-- Corner decorations -->
  <g opacity="0.6">
    <circle cx="30" cy="30" r="6" fill="#FFFFFF"/>
    <circle cx="370" cy="30" r="6" fill="#FFFFFF"/>
    <circle cx="30" cy="270" r="6" fill="#FFFFFF"/>
    <circle cx="370" cy="270" r="6" fill="#FFFFFF"/>
  </g>
  
  <!-- Texture overlay -->
  <rect width="400" height="300" fill="url(#indigo-bg)" opacity="0.1"/>
</svg>
