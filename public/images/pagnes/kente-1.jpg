<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="400" height="300">
  <!-- Kente Cloth Pattern -->
  <defs>
    <!-- Stripe patterns -->
    <pattern id="kente-pattern" patternUnits="userSpaceOnUse" width="80" height="80">
      <rect width="80" height="80" fill="#FFD700"/>
      <rect x="0" y="0" width="20" height="80" fill="#228B22"/>
      <rect x="40" y="0" width="20" height="80" fill="#FF6347"/>
      <rect x="0" y="0" width="80" height="20" fill="#000000" opacity="0.3"/>
      <rect x="0" y="40" width="80" height="20" fill="#000000" opacity="0.3"/>
    </pattern>
  </defs>
  
  <!-- Base Kente -->
  <rect width="400" height="300" fill="url(#kente-pattern)"/>
  
  <!-- Vertical stripes -->
  <g opacity="0.8">
    <rect x="0" y="0" width="15" height="300" fill="#FF6347"/>
    <rect x="95" y="0" width="15" height="300" fill="#228B22"/>
    <rect x="190" y="0" width="15" height="300" fill="#000000"/>
    <rect x="285" y="0" width="15" height="300" fill="#FF6347"/>
    <rect x="385" y="0" width="15" height="300" fill="#228B22"/>
  </g>
  
  <!-- Horizontal stripes -->
  <g opacity="0.8">
    <rect x="0" y="0" width="400" height="12" fill="#000000"/>
    <rect x="0" y="72" width="400" height="12" fill="#FF6347"/>
    <rect x="0" y="144" width="400" height="12" fill="#228B22"/>
    <rect x="0" y="216" width="400" height="12" fill="#FFD700"/>
    <rect x="0" y="288" width="400" height="12" fill="#000000"/>
  </g>
  
  <!-- Geometric symbols -->
  <g fill="#FFFFFF" opacity="0.4">
    <rect x="50" y="50" width="20" height="20"/>
    <rect x="150" y="50" width="20" height="20"/>
    <rect x="250" y="50" width="20" height="20"/>
    <rect x="350" y="50" width="20" height="20"/>
    
    <rect x="50" y="130" width="20" height="20"/>
    <rect x="150" y="130" width="20" height="20"/>
    <rect x="250" y="130" width="20" height="20"/>
    <rect x="350" y="130" width="20" height="20"/>
    
    <rect x="50" y="230" width="20" height="20"/>
    <rect x="150" y="230" width="20" height="20"/>
    <rect x="250" y="230" width="20" height="20"/>
    <rect x="350" y="230" width="20" height="20"/>
  </g>
</svg>
