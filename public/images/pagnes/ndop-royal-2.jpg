<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 300" width="400" height="300">
  <!-- Ndop Royal variation 2 -->
  <rect width="400" height="300" fill="#1B3A5C"/>
  
  <!-- White diamond pattern -->
  <g fill="#FFFFFF" opacity="0.9">
    <polygon points="50,50 100,100 50,150 0,100"/>
    <polygon points="150,50 200,100 150,150 100,100"/>
    <polygon points="250,50 300,100 250,150 200,100"/>
    <polygon points="350,50 400,100 350,150 300,100"/>
    
    <polygon points="50,150 100,200 50,250 0,200"/>
    <polygon points="150,150 200,200 150,250 100,200"/>
    <polygon points="250,150 300,200 250,250 200,200"/>
    <polygon points="350,150 400,200 350,250 300,200"/>
  </g>
  
  <!-- Gold accents -->
  <g fill="#D4A574">
    <circle cx="50" cy="100" r="12"/>
    <circle cx="150" cy="100" r="12"/>
    <circle cx="250" cy="100" r="12"/>
    <circle cx="350" cy="100" r="12"/>
    
    <circle cx="50" cy="200" r="12"/>
    <circle cx="150" cy="200" r="12"/>
    <circle cx="250" cy="200" r="12"/>
    <circle cx="350" cy="200" r="12"/>
  </g>
  
  <!-- Spider motifs in diamonds -->
  <g fill="#D4A574" opacity="0.6">
    <circle cx="150" cy="100" r="8"/>
    <circle cx="250" cy="200" r="8"/>
  </g>
</svg>
